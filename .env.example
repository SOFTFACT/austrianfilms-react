# Vite env template — committed reference. Copy to .env.local (gitignored via *.local)
# and fill in the real token. Vars must be prefixed VITE_ to be exposed to the client.
#
# SECURITY: Vite inlines VITE_* values into the built JS bundle, so any token here is
# visible to anyone who loads the app. For production, prefer proxying LLM calls through
# the 4D backend (which holds the token server-side) instead of shipping VITE_LLM_TOKEN.
#
# LLM endpoint (OpenAI-compatible, LM Studio). Server A is the default/primary.
VITE_LLM_BASE_URL=http://212.186.251.28:1234/v1
VITE_LLM_TOKEN=<LM_STUDIO_API_TOKEN>
VITE_LLM_MODEL=google/gemma-4-e4b
VITE_LLM_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Fallback endpoint (Server B, ~3.8x slower)
VITE_LLM_FALLBACK_BASE_URL=https://ai.softfact.com/v1
VITE_LLM_FALLBACK_TOKEN=<LM_STUDIO_API_TOKEN>
